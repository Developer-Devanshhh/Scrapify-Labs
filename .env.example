# =============================================================================
# Scrapify Labs — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# App
APP_NAME=ScrapifyLabs
APP_ENV=development
APP_PORT=8000
APP_LOG_LEVEL=INFO

# Database (SQLite path relative to project root)
DATABASE_URL=sqlite:///./scrapify.db

# Reddit (PRAW) — https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ScrapifyLabs/1.0

# YouTube Data API v3 — https://console.cloud.google.com/apis
YOUTUBE_API_KEY=

# Twitter/X (twscrape) — accounts for cookie pool
# Format: username:password:email:email_password (one per line)
TWITTER_ACCOUNTS=

# Instagram (instaloader) — optional, public data works without
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# Webhook — callback URL for main governance platform
WEBHOOK_URL=
WEBHOOK_SECRET=

# Scheduler
SCRAPE_INTERVAL_MINUTES=60
