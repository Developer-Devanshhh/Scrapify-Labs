# =============================================================================
# Scrapify Labs — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# App
APP_NAME=ScrapifyLabs
APP_ENV=development
APP_PORT=8000
APP_LOG_LEVEL=INFO

# Database (SQLite path relative to project root)
DATABASE_URL=sqlite:///./scrapify.db

# Reddit (PRAW) — https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ScrapifyLabs/1.0

# YouTube Data API v3 — https://console.cloud.google.com/apis
YOUTUBE_API_KEY=

# Twitter/X — accounts for twscrape + cookies for Playwright stealth
# Format: username:password:email:email_password (one per line)
TWITTER_ACCOUNTS=
# Browser cookies (extract from Chrome DevTools → Application → Cookies → x.com)
TWITTER_AUTH_TOKEN=
TWITTER_CT0=

# Instagram — credentials for instaloader + session for Playwright stealth
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
# Browser cookie (extract from Chrome DevTools → Application → Cookies → instagram.com)
INSTAGRAM_SESSION_ID=

# Apify (free tier — $5/mo credits for social media at scale)
# Get your token at https://console.apify.com/account/integrations
APIFY_API_TOKEN=

# Google Maps Places API — for hyper-local reviews + geo-coordinates
# Get at https://console.cloud.google.com/apis (enable Places API)
GOOGLE_MAPS_API_KEY=

# Google Custom Search API (optional — search news/blogs for city issues)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=

# Google Gemini Flash — LLM structuring of scraped data
# Get at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# City-Scoped Demo — focus all scrapers on a single city
DEMO_CITY=Chennai

# News APIs
GNEWS_API_KEY=
CURRENTS_API_KEY=
NEWSDATA_API_KEY=

# Webhook — callback URL for main governance platform
WEBHOOK_URL=
WEBHOOK_SECRET=

# Scheduler
SCRAPE_INTERVAL_MINUTES=60
